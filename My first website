    <style>
      :root {
        --bg: #07111f;
        --panel: #0f172a;
        --panel-2: #111827;
        --text: #e5eefb;
        --muted: #bfcced;
        --accent: #38bdf8;
        --accent-2: #a78bfa;
        --good: #22c55e;
        --border: rgba(148, 163, 184, 0.18);
      }

      * { box-sizing: border-box; }

      body {
        margin: 0;
        font-family: Arial, Helvetica, sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top, rgba(56, 189, 248, 0.08), transparent 25%),
          linear-gradient(135deg, var(--bg), #020617 60%);
        min-height: 100vh;
      }

      .page {
        width: min(1200px, calc(100% - 24px));
        margin: 0 auto;
        padding: 24px 0 40px;
      }

      .hero, .card, .mini-card {
        background: linear-gradient(180deg, rgba(15, 23, 42, 0.96), rgba(8, 15, 28, 0.98));
        border: 1px solid var(--border);
        border-radius: 24px;
        box-shadow: 0 18px 40px rgba(15, 23, 42, 0.45);
      }

      .hero {
        display: grid;
        grid-template-columns: 1.1fr 0.9fr;
        gap: 24px;
        padding: 28px;
        align-items: center;
      }

      .eyebrow {
        display: inline-block;
        font-size: 0.88rem;
        text-transform: uppercase;
        letter-spacing: 0.25em;
        color: #bae6fd;
        margin-bottom: 10px;
      }

      h1 {
        font-size: clamp(2rem, 6vw, 3.4rem);
        line-height: 1.08;
        margin: 0 0 12px;
      }

      .lead {
        color: var(--muted);
        font-size: 1.04rem;
        margin-bottom: 16px;
      }

      .pill-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin: 18px 0 8px;
      }

      .pill {
        border: 1px solid rgba(56, 189, 248, 0.35);
        color: #d7f3ff;
        background: rgba(14, 165, 233, 0.08);
        border-radius: 999px;
        padding: 8px 12px;
        font-size: 0.92rem;
      }

      .cta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 18px;
      }

      .btn {
        text-decoration: none;
        border-radius: 12px;
        padding: 10px 14px;
        font-weight: 700;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }

      .btn-primary {
        background: linear-gradient(135deg, var(--accent), #2563eb);
        color: #fff;
      }

      .btn-secondary {
        color: var(--text);
        border: 1px solid var(--border);
        background: rgba(15, 23, 42, 0.9);
      }

      .stat-grid {
        display: grid;
        gap: 12px;
      }

      .mini-card {
        padding: 14px;
      }

      .mini-card strong {
        display: block;
        font-size: 1.3rem;
        color: #fff;
        margin-bottom: 4px;
      }

      section {
        margin-top: 22px;
      }

      .section-head {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 12px;
        margin-bottom: 12px;
      }

      .section-head h2 {
        margin: 0;
        font-size: 1.35rem;
      }

      .section-head p {
        margin: 4px 0 0;
        color: var(--muted);
        font-size: 0.95rem;
      }

      .grid-2, .grid-3 {
        display: grid;
        gap: 14px;
      }

      .grid-2 { grid-template-columns: repeat(2, 1fr); }
      .grid-3 { grid-template-columns: repeat(3, 1fr); }

      .card {
        padding: 16px;
      }

      .tag {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        border-radius: 999px;
        background: rgba(167, 139, 250, 0.12);
        color: #ddd6fe;
        font-size: 0.82rem;
        padding: 6px 10px;
        margin-bottom: 8px;
      }

      .card h3 {
        margin: 0 0 6px;
        font-size: 1.02rem;
      }

      .card p {
        color: var(--muted);
        font-size: 0.95rem;
        line-height: 1.45;
        margin: 0 0 10px;
      }

      .meta {
        display: flex;
        justify-content: space-between;
        gap: 10px;
        color: #dbeafe;
        font-size: 0.92rem;
      }

      .salary {
        color: #bbf7d0;
        font-weight: 700;
      }

      .highlight-box {
        background: linear-gradient(135deg, rgba(34, 197, 94, 0.09), rgba(56, 189, 248, 0.08));
        border: 1px solid rgba(34, 197, 94, 0.18);
        border-radius: 18px;
        padding: 14px;
      }

      .highlight-box h3 { margin-top: 0; }

      @media (max-width: 980px) {
        .hero { grid-template-columns: 1fr; }
        .grid-3 { grid-template-columns: 1fr 1fr; }
      }

      @media (max-width: 700px) {
        .grid-2, .grid-3 { grid-template-columns: 1fr; }
        .page { width: min(100% - 16px, 1200px); padding-top: 12px; }
        .hero, .card, .mini-card { border-radius: 18px; }
        .section-head { align-items: start; flex-direction: column; }
      }
    </style>
  </head>
